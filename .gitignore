# PRISM .gitignore
# Simplified and organized

# =========================
# Build Output
# =========================
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.o
*.a
*.lib

# Build directories
frontend/dist/
frontend/build/
.release/

# =========================
# Dependencies
# =========================
node_modules/
vendor/
__pycache__/

# =========================
# Environment & Secrets
# =========================
.env*
*.env
*.pem
*.key
*.crt

# =========================
# Logs & Database
# =========================
*.log
logs/
*.db
*.sqlite
*.sqlite3

# =========================
# IDE & OS
# =========================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =========================
# AI Settings (Local Only)
# =========================
.qwen/settings.json
.qwen/settings.local.json
.claude/settings.local.json

# =========================
# Test Output (Keep Test Files)
# =========================
coverage/
coverage.txt
go.coverage
tsc_errors.txt
lint_output.txt

# =========================
# Temporary
# =========================
tmp/
temp/
.cache/
*.bak
*.tmp
